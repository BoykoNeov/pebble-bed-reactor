; Engine configuration file.
; Pebble Bed — 2D toy pebble bed reactor simulator (see CLAUDE.md).

config_version=5

[application]

config/name="Pebble Bed"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[display]

window/size/viewport_width=720
window/size/viewport_height=1080

[physics]

; Raise solver iterations: granular stacking is jittery/spongy with the default;
; more iterations buys quieter quasi-static settling (CLAUDE.md pitfall).
2d/solver/solver_iterations=32
common/physics_ticks_per_second=60
