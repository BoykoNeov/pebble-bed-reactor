; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pebble Bed"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[display]

window/size/viewport_width=1200
window/size/viewport_height=1080
; Scale the whole canvas to whatever window the OS actually grants instead of
; cropping it: on a 1080p screen at 125-150% display scale the bare window is
; smaller than the viewport and, without stretch, the reactor is cut off.
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

environment/defaults/default_clear_color=Color(0.05, 0.06, 0.09, 1)

[physics]

; Raised from the default: granular stacking is jittery/spongy otherwise; more
; iterations buy quieter quasi-static settling (CLAUDE.md pitfall). The editor
; may strip this comment on save — the rationale also lives in CLAUDE.md.
2d/solver/solver_iterations=32

[input]

toggle_feedback={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":16,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":70,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
